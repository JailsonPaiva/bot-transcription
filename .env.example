# Copie para .env localmente. No Render, configure Environment Variables no Dashboard.

# Meta / WhatsApp Cloud API
VERIFY_TOKEN=
META_WA_TOKEN=
WA_PHONE_NUMBER_ID=
META_APP_SECRET=
REQUIRE_WEBHOOK_SIGNATURE=false

# Mensageria / STT / LLM
MESSAGE_SERVICE=whatsapp
TRANSCRIPTION_SERVICE=gladia
ENABLE_GEMINI_CORRECTION=true
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_KEY=
GLADIA_API_KEY=
LOCAL_WHATSAPP_ENABLED=false

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET_NAME=bot_orcamento

# Redis (na Render: injetado pelo Key Value via REDIS_URL)
REDIS_URL=redis://localhost:6379/0
USE_REDIS=true
DEDUPE_TTL_SECONDS=86400
SESSION_TTL_SECONDS=1800

# Resiliência
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF_SECONDS=1.5
MAX_AUDIO_PER_HOUR=20

# Branding do PDF (opcional)
PDF_COMPANY_NAME=Sua Empresa de Materiais
PDF_TAGLINE=Orçamentos para obra, direto no WhatsApp
PDF_LOGO_PATH=
PDF_PHONE=
PDF_WEBSITE=
PDF_PRIMARY_COLOR=27,54,93
PDF_ACCENT_COLOR=242,141,62
PDF_VALIDADE_DIAS=7

# Render define PORT automaticamente; local:
# PORT=8000
